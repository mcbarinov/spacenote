# === Backend ===
SPACENOTE_DATABASE_URL=mongodb://localhost:27017/spacenote
SPACENOTE_SITE_URL=http://localhost:3000
SPACENOTE_HOST=0.0.0.0
SPACENOTE_PORT=3100
SPACENOTE_PORT_AGENT=3101
SPACENOTE_DEBUG=true
SPACENOTE_CORS_ORIGINS='["http://localhost:*"]'
SPACENOTE_DATA_DIR=./data
# SPACENOTE_TELEGRAM_BOT_TOKEN=
# SPACENOTE_MAX_UPLOAD_SIZE=524288000

# --- Dev override pattern (feat/blob-storage) ---
# When working on the blob-storage refactor, point the backend at an isolated
# database and data directory so the existing local environment is not touched.
# Override these two vars (do NOT change the defaults above):
#   SPACENOTE_DATABASE_URL=mongodb://localhost:27017/spacenote_blob
#   SPACENOTE_DATA_DIR=~/.spacenote-blob-dev/data

# === Frontend ===
VITE_FRONTEND_PORT=3000
VITE_FRONTEND_PORT_AGENT=3001
VITE_API_URL=http://localhost:3100
VITE_API_URL_AGENT=http://localhost:3101
