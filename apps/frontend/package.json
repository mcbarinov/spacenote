{
  "name": "@spacenote/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write . | grep -v '(unchanged)' || true",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "preview": "vite preview",
    "routes": "tsr generate",
    "openapi": "openapi-typescript http://localhost:3100/openapi.json -o src/types/openapi.gen.ts --export-type"
  },
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/dates": "^8.3.18",
    "@mantine/form": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/modals": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.4",
    "ky": "^1.14.3",
    "liquidjs": "^10.25.2",
    "mantine-form-zod-resolver": "^1.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-live": "^4.1.8",
    "rehype": "^13.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/router-cli": "^1.166.19",
    "@tanstack/router-plugin": "^1.167.5",
    "@tanstack/virtual-file-routes": "^1.161.7",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-mantine": "^4.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-dom": "^3.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^3.0.0",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2"
  }
}
